{
  "manifest_version": 3,
  "name": "NotebookOS",
  "version": "1.0.0",
  "description": "Your browser's college bag. Context-aware notes, linked to every webpage.",

  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "contextMenus",
    "sidePanel"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Open NotebookOS",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "side_panel": {
    "default_path": "pages/sidepanel.html"
  },

  "background": {
    "service_worker": "scripts/background.js"
  },

  "options_page": "pages/dashboard.html"
}
